    "@amazon-devices/react-native-screens": "~3.0.0",
    "@amazon-devices/react-native-svg": "~3.0.0",
    "@amazon-devices/react-native-vector-icons": "~2.1.0",
    "@amazon-devices/react-native-w3cmedia": "~2.3.0",
    "@amazon-devices/vega-carousel": "~1.0.0",
    "@amazon-devices/react-navigation__core": "~8.0.0",
