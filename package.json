{
  "name": "@amazon-devices/Keplervideoapp",
  "version": "2.22.1",
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rm -rf build bundle kepler-build node_modules package-lock.json generated coverage shaka-setup/shaka-player",
    "postinstall": "cd shaka-setup && ./build.sh && ./copyOutputs.sh",
    "build": "npm-run-all compile lint:fix test",
    "compile": "tsc -p tsconfig.json",
    "test:snapshot": "jest --colors --updateSnapshot",
    "start": "react-native start",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest --colors --coverage",
    "test:clearCache": "jest --clearCache",
    "lint": "eslint src --ext .ts,.tsx && eslint test --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix && eslint test --ext .ts,.tsx --fix",
    "start:simulator": "kepler device simulator start",
    "app:install": "kepler device install-app --dir .",
    "app:install:debug": "kepler device install-app -b Debug --dir .",
    "app:launch": "kepler device launch-app",
    "app:build:debug": "run-s build:debug && npm run app:install:debug && npm run app:launch",
    "app:build": "run-s build:release && npm run app:install && npm run app:launch",
    "build:release": "react-native build-kepler --build-type Release",
    "build:debug": "react-native build-kepler --build-type Debug",
    "build:app": "npm-run-all build:release build:debug"
  },
  "dependencies": {
    "@amazon-devices/headless-task-manager": "~1.2.0",
    "@amazon-devices/kepler-channel": "~1.1.0",
    "@amazon-devices/kepler-content-personalization": "~1.2.0",
    "@amazon-devices/kepler-epg-provider": "~1.9.0",
    "@amazon-devices/kepler-epg-sync-scheduler": "~1.2.0",
    "@amazon-devices/kepler-file-system": "~0.0.1",
    "@amazon-devices/kepler-media-account-login": "~1.1.0",
    "@amazon-devices/kepler-media-content-launcher": "~2.0.2",
    "@amazon-devices/kepler-media-controls": "~1.0.0",
    "@amazon-devices/kepler-media-types": "~1.0.0",
    "@amazon-devices/kepler-ui-components": "~3.1.0",
    "@amazon-devices/keplerscript-appstore-iap-lib": "~2.13.0",
    "@amazon-devices/keplerscript-netmgr-lib": "~2.0.0",
    "@amazon-devices/lottie-react-native": "~3.0.0",
    "@amazon-devices/react-linear-gradient": "~2.0.0",
